{
  "compilerOptions": {
    "target": "es2020",
    "module": "CommonJS",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "moduleResolution": "node",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
      "types": ["node"],
      "typeRoots": ["./node_modules/@types"]
  }
}
